# Application Configuration
# Copy this file to .env and update values for your environment

# MongoDB connection string
APP_MONGODB_URL=mongodb://admin:admin123@localhost:27017/reconciliation?authSource=admin

# Database name
APP_DB_NAME=reconciliation

# Logging configuration
APP_LOG_LEVEL=INFO
APP_LOG_FORMAT=json

# Application name
APP_APP_NAME=reconciliation-ingestion

# SFTP configuration (optional — for file ingestion)
SFTP_HOST=localhost
SFTP_PORT=2222
SFTP_USER=foo
SFTP_PASS=pass
SFTP_REMOTE_DIR=/upload
