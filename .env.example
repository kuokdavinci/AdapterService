# Application Configuration
# Copy this file to .env and update values for your environment

# MongoDB connection credentials (for Docker Compose and connection URL)
MONGO_ROOT_USER=admin
MONGO_ROOT_PASSWORD=your_secure_password

# MongoDB connection string
APP_MONGODB_URL=mongodb://${MONGO_ROOT_USER}:${MONGO_ROOT_PASSWORD}@localhost:27017/reconciliation?authSource=admin

# Database name
APP_DB_NAME=reconciliation

# Logging configuration
APP_LOG_LEVEL=INFO
APP_LOG_FORMAT=json

# Application name
APP_APP_NAME=reconciliation-ingestion

# SFTP configuration (for Docker Compose and file ingestion)
SFTP_HOST=localhost
SFTP_PORT=2222
SFTP_USER=foo
SFTP_PASS=your_sftp_password
SFTP_REMOTE_DIR=/upload
